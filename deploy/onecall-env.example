# Copy to /opt/onecall-locator-dashboard/.env on the cloud server.
# Do not commit the real .env file with client IDs or token paths.

# Microsoft Entra app registration application/client ID.
# The app must allow public client flows and include delegated Microsoft Graph permissions:
# Mail.Read, User.Read, offline_access.
OUTLOOK_GRAPH_CLIENT_ID=

# Use consumers for a personal Outlook/Hotmail account, organizations for work/school,
# or common if you need either.
OUTLOOK_GRAPH_TENANT=consumers

# Pull read and unread ticket emails so tickets are not missed if the mailbox is opened elsewhere.
OUTLOOK_INCLUDE_READ=1
OUTLOOK_DAYS_BACK=7
OUTLOOK_GRAPH_FOLDER=inbox
OUTLOOK_TICKET_OUTPUT_DIR=/opt/onecall-locator-dashboard/data/inbox
OUTLOOK_GRAPH_TOKEN_CACHE=/opt/onecall-locator-dashboard/data/private/outlook_graph_token.json

# Google Maps Platform Map Tiles API key.
# Enable the Map Tiles API in Google Cloud and restrict this browser key to the
# dashboard origins that serve the app.
GOOGLE_MAPS_TILE_API_KEY=

# Mapbox access token for Mapbox basemaps in the Base map menu.
# Restrict this public token to the dashboard origins that serve the app.
MAPBOX_ACCESS_TOKEN=

# Private activity viewer and shared dashboard writer controls.
AUDIT_VIEW_USERS=site_owner
SHARED_DASHBOARD_WRITE_USERS=administrator,site_owner

# VETRO export refresh. The Update VETRO button requires this API token.
VETRO_PLAN_ID=462
VETRO_TOKEN=
VETRO_LOGIN_URL=https://auth.vetro.io/login?redirect=https://app.vetro.io/fibermap/map

# OneDrive attachment uploads.
# Create a Microsoft public-client app and grant delegated Files.ReadWrite and User.Read.
# The dashboard stores the refresh token in data/private, not in Git.
ONEDRIVE_GRAPH_CLIENT_ID=
ONEDRIVE_GRAPH_TENANT=consumers
ONEDRIVE_GRAPH_SCOPE=offline_access Files.ReadWrite User.Read
ONEDRIVE_GRAPH_TOKEN_CACHE=/opt/onecall-locator-dashboard/data/private/onedrive_graph_token.json
ONEDRIVE_ATTACHMENTS_ROOT=Fiber Locator Attachments
ONEDRIVE_LINK_SCOPE=anonymous
